@baseUrl = http://localhost:8787
@token = PASTE_TOKEN_HERE

### Health
GET {{baseUrl}}/api/health

###

### Login - admin
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "admin@test.com",
  "password": "admin123"
}

###

### Login - user
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "user@test.com",
  "password": "user123"
}

###

### Get settings - user 2
GET {{baseUrl}}/api/settings/2
Authorization: Bearer {{token}}

###

### Update settings - user 2
PUT {{baseUrl}}/api/settings/2
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "training": {
    "workSeconds": 45,
    "restSeconds": 15,
    "rounds": 4
  },
  "focus": {
    "focusSeconds": 1500,
    "shortBreakSeconds": 300,
    "cycles": 4
  }
}

###

### Start training session - user 2
POST {{baseUrl}}/api/session/start
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "userId": "2",
  "mode": "training"
}

###

### Pause session - user 2
POST {{baseUrl}}/api/session/pause
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "userId": "2"
}

###

### Resume session - user 2
POST {{baseUrl}}/api/session/resume
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "userId": "2"
}

###

### Stop session - user 2
POST {{baseUrl}}/api/session/stop
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "userId": "2"
}

###

### Complete session - user 2
POST {{baseUrl}}/api/session/complete
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "userId": "2"
}

###

### Get active session - user 2
GET {{baseUrl}}/api/session/2
Authorization: Bearer {{token}}

###

### Get history - user 2
GET {{baseUrl}}/api/history/2
Authorization: Bearer {{token}}

###

### Get admin telemetry
GET {{baseUrl}}/api/admin/telemetry
Authorization: Bearer {{token}}

###

### Get admin alerts
GET {{baseUrl}}/api/admin/alerts
Authorization: Bearer {{token}}

###

### Get admin rules
GET {{baseUrl}}/api/admin/rules
Authorization: Bearer {{token}}

###

### Update failed login threshold
PUT {{baseUrl}}/api/admin/rules/failed_logins_spike
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "threshold": 2,
  "enabled": true
}